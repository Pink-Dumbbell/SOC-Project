alert tcp any any -> any 22 (msg:"SOC SSH Scan Detected"; flags:S; threshold:type threshold, track by_src, count 5, seconds 10; sid:1000001; rev:1;)

alert tcp any any -> any 80 (msg:"SOC HTTP Access Detected"; sid:1000002; rev:1;)

alert icmp any any -> any any (msg:"SOC ICMP Ping Detected"; sid:1000003; rev:1;)
