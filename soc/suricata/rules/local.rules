##############################################
# 1. TCP SYN Port Scan
##############################################
alert tcp any any -> $HOME_NET any (
    msg:"SOC Port Scan - SYN";
    flags:S;
    threshold:type both, track by_src, count 20, seconds 5;
    sid:1000001;
    rev:1;
)

##############################################
# 2. TCP FIN Scan
##############################################
alert tcp any any -> $HOME_NET any (
    msg:"SOC Port Scan - FIN";
    flags:F;
    threshold:type both, track by_src, count 10, seconds 5;
    sid:1000002;
    rev:1;
)

##############################################
# 3. TCP NULL Scan
##############################################
alert tcp any any -> $HOME_NET any (
    msg:"SOC Port Scan - NULL";
    flags:0;
    threshold:type both, track by_src, count 10, seconds 5;
    sid:1000003;
    rev:1;
)

##############################################
# 4. TCP XMAS Scan
##############################################
alert tcp any any -> $HOME_NET any (
    msg:"SOC Port Scan - XMAS";
    flags:FPU;
    threshold:type both, track by_src, count 10, seconds 5;
    sid:1000004;
    rev:1;
)

##############################################
# 5. UDP Scan
##############################################
alert udp any any -> $HOME_NET any (
    msg:"SOC UDP Scan";
    threshold:type both, track by_src, count 20, seconds 5;
    sid:1000005;
    rev:1;
)

##############################################
# 6. ICMP Flood
##############################################
alert icmp any any -> $HOME_NET any (
    msg:"SOC ICMP Flood";
    threshold:type both, track by_src, count 30, seconds 5;
    sid:1000006;
    rev:1;
)

##############################################
# 7. SSH Brute Force
##############################################
alert tcp any any -> $HOME_NET 22 (
    msg:"SOC SSH Brute Force";
    flow:to_server;
    threshold:type both, track by_src, count 5, seconds 60;
    sid:1000007;
    rev:1;
)

##############################################
# 8. FTP Brute Force
##############################################
alert tcp any any -> $HOME_NET 21 (
    msg:"SOC FTP Brute Force";
    flow:to_server;
    threshold:type both, track by_src, count 5, seconds 60;
    sid:1000008;
    rev:1;
)

##############################################
# 9. sqlmap Scanner
##############################################
alert http any any -> $HOME_NET any (
    msg:"SOC Scanner - sqlmap";
    http.user_agent;
    content:"sqlmap";
    nocase;
    sid:1000009;
    rev:1;
)

